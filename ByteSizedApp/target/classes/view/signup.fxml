<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.SignupController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Create Account"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="nameField"
               promptText="Full Name"
               maxWidth="260"/>

    <TextField fx:id="emailField"
               promptText="Email"
               maxWidth="260"/>

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   maxWidth="260"/>

    <Label text="Password must be 8+ characters with uppercase and number"
           style="-fx-font-size: 10px; -fx-text-fill: gray;"
           wrapText="true"
           maxWidth="260"/>

    <Label fx:id="captchaLabel"
           text="CAPTCHA"
           style="-fx-font-weight: bold;" />

    <TextField fx:id="captchaField"
               promptText="Solve CAPTCHA"
               maxWidth="260"/>

    <Button text="Create Account"
            onAction="#handleCreateAccount"
            maxWidth="260"
            style="-fx-background-color: #0066cc; -fx-text-fill: white;"/>

    <Button text="Back to Login"
            onAction="#handleBackToLogin"
            maxWidth="260"/>

    <Label fx:id="errorLabel"
           textFill="red"
           wrapText="true"
           maxWidth="260"/>

</VBox>
